{
  "manifest_version": 3,
  "name": "Toggle Dark Mode For Google Docs",
  "description": "Toggle dark mode for Google Docs pages.",
  "version": "1.1",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://docs.google.com/document/u/*/"
  ],

  "action": {
    "default_title": "Toggle Dark Mode",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  }
}